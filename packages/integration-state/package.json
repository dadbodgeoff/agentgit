    "test": "vitest run --dir src",
    "prepack": "pnpm run build",
    "lint": "eslint . --max-warnings=0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  },
  "dependencies": {
    "@agentgit/schemas": "workspace:*",
    "better-sqlite3": "^12.8.0"
  }
}
