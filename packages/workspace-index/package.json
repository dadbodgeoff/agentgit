{
  "name": "@agentgit/workspace-index",
  "version": "0.1.0",
  "private": false,
  "description": "Workspace metadata index used by AgentGit snapshot and restore flows.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dadbodgeoff/agentgit.git",
    "directory": "packages/workspace-index"
  },
  "homepage": "https://github.com/dadbodgeoff/agentgit/tree/main/packages/workspace-index",
  "bugs": {
    "url": "https://github.com/dadbodgeoff/agentgit/issues"
  },
  "keywords": [
    "agent",
    "workspace",
    "index",
    "snapshot",
    "sqlite"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run --dir src",
    "prepack": "node ../../scripts/verify-package-build.mjs",
    "lint": "eslint . --max-warnings=0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  },
  "dependencies": {
    "@agentgit/schemas": "workspace:*",
    "better-sqlite3": "^12.8.0"
  }
}
