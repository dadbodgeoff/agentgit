{
  "name": "@agentgit/agent-runtime-integration",
  "version": "0.1.0",
  "private": false,
  "description": "Productized runtime integration layer and product CLI for AgentGit.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dadbodgeoff/agentgit.git",
    "directory": "packages/agent-runtime-integration"
  },
  "homepage": "https://github.com/dadbodgeoff/agentgit/tree/main/packages/agent-runtime-integration",
  "bugs": {
    "url": "https://github.com/dadbodgeoff/agentgit/issues"
  },
  "keywords": [
    "agent",
    "authority",
    "cli",
    "runtime",
    "governance"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentgit": "dist/main.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "test": "pnpm --filter @agentgit/authority-daemon build && vitest run --dir src",
    "start": "node dist/main.js"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0"
  },
  "dependencies": {
    "@agentgit/credential-broker": "workspace:*",
    "@agentgit/authority-daemon": "workspace:*",
    "@agentgit/authority-sdk": "workspace:*",
    "@agentgit/integration-state": "workspace:*",
    "@agentgit/schemas": "workspace:*"
  }
}
