{
  "name": "@agentgit/control-plane-state",
  "version": "0.1.0",
  "private": false,
  "description": "Durable connector and sync state for the AgentGit cloud control plane.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run --dir src",
    "prepack": "node ../../scripts/verify-package-build.mjs",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@agentgit/cloud-sync-protocol": "workspace:*",
    "@agentgit/integration-state": "workspace:*",
    "@agentgit/schemas": "workspace:*",
    "zod": "^4.3.6"
  }
}
