{
  "name": "@agentgit/snapshot-engine",
  "version": "0.1.0",
  "private": false,
  "description": "Snapshot selection, capture, and restore metadata primitives for AgentGit recovery flows.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dadbodgeoff/agentgit.git",
    "directory": "packages/snapshot-engine"
  },
  "homepage": "https://github.com/dadbodgeoff/agentgit/tree/main/packages/snapshot-engine",
  "bugs": {
    "url": "https://github.com/dadbodgeoff/agentgit/issues"
  },
  "keywords": [
    "agent",
    "snapshot",
    "recovery",
    "restore",
    "workspace"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run --dir src",
    "prepack": "node ../../scripts/verify-package-build.mjs",
    "lint": "eslint . --max-warnings=0"
  },
  "devDependencies": {
    "@agentgit/test-fixtures": "workspace:*"
  },
  "dependencies": {
    "@agentgit/schemas": "workspace:*",
    "@agentgit/workspace-index": "workspace:*"
  }
}
