{
  "name": "@agentgit/snapshot-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run --dir src"
  },
  "devDependencies": {
    "@agentgit/test-fixtures": "workspace:*"
  },
  "dependencies": {
    "@agentgit/schemas": "workspace:*",
    "@agentgit/workspace-index": "workspace:*"
  }
}
