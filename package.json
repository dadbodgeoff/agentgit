{
  "name": "agentgit",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test --filter=!@agentgit/schemas --filter=!@agentgit/test-fixtures -- --coverage.enabled --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=json-summary --coverage.reporter=lcov --coverage.thresholds.lines=50 --coverage.thresholds.functions=50 --coverage.thresholds.statements=50 --coverage.thresholds.branches=40 && pnpm --filter @agentgit/schemas test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check \"./{apps,packages,scripts,.github}/**/*.{ts,tsx,js,mjs,cjs,json,yml,yaml}\" \"./*.{json,mjs,yml,yaml}\"",
    "format:write": "prettier --write \"./{apps,packages,scripts,.github}/**/*.{ts,tsx,js,mjs,cjs,json,yml,yaml}\" \"./*.{json,mjs,yml,yaml}\"",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "daemon:start": "pnpm --filter @agentgit/authority-daemon start",
    "cli": "pnpm --filter @agentgit/authority-cli exec -- node dist/main.js",
    "py:test": "PYTHONPATH=packages/authority-sdk-py python3 -m unittest discover -s packages/authority-sdk-py/tests -v",
    "py:demo": "PYTHONPATH=packages/authority-sdk-py python3 packages/authority-sdk-py/examples/governed_run.py",
    "smoke:py": "PYTHONPATH=packages/authority-sdk-py python3 packages/authority-sdk-py/examples/governed_run.py --workspace-root \"$PWD\"",
    "security:audit:node": "pnpm audit --audit-level=high --prod",
    "security:audit:python": "node scripts/audit-python-dependencies.mjs",
    "security:audit": "pnpm security:audit:node && pnpm security:audit:python",
    "release:verify:claims": "node scripts/verify-release-scope-claims.mjs",
    "release:verify:coverage-ratchet": "node scripts/verify-coverage-ratchet.mjs",
    "release:pack": "node scripts/pack-release-artifacts.mjs",
    "release:verify:artifacts": "node scripts/verify-release-artifacts.mjs --artifacts-dir .release-artifacts/packed --signature-mode allow-unsigned",
    "smoke:cli-install": "node scripts/smoke-installed-cli.mjs",
    "smoke:agent-runtime": "node scripts/smoke-agent-runtime.mjs",
    "smoke:cli-compat": "node scripts/verify-cli-compatibility.mjs",
    "release:verify": "pnpm lint && pnpm format:check && pnpm release:verify:claims && pnpm release:verify:coverage-ratchet && pnpm security:audit && pnpm test:coverage && pnpm py:test && pnpm smoke:cli-install && pnpm smoke:cli-compat",
    "release:publish": "pnpm changeset publish --access public"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@changesets/cli": "^2.29.7",
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^4.0.8",
    "esbuild": "^0.25.11",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "turbo": "^2.8.21",
    "typescript-eslint": "^8.46.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
