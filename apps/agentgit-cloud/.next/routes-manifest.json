  "dynamicRoutes": [
    {
      "page": "/api/v1/repos/[repoId]/calibration",
      "regex": "^/api/v1/repos/([^/]+?)/calibration(?:/)?$",
      "routeKeys": {
        "nxtPrepoId": "nxtPrepoId"
      },
      "namedRegex": "^/api/v1/repos/(?<nxtPrepoId>[^/]+?)/calibration(?:/)?$"
    },
    {
