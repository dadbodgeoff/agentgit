# AgentGit Cloud deployment environment
# Copy to `.env.local` for local testing or load these variables into your host.
# Values marked "Required in production" must exist before you treat the app as launch-ready.

# -----------------------------------------------------------------------------
# Authentication and session security
# -----------------------------------------------------------------------------

# Required in production.
# Long random secret used to sign NextAuth session cookies.
# Generate with: `openssl rand -base64 32`
AUTH_SECRET=replace-with-a-long-random-secret

# Required in production.
# Public base URL for the hosted cloud app. Must match the OAuth callback host.
# Example: https://cloud.agentgit.example
AUTH_URL=https://cloud.agentgit.example

# Required in production.
# NextAuth callback URL. Keep this aligned with AUTH_URL unless your platform requires otherwise.
NEXTAUTH_URL=https://cloud.agentgit.example

# Required in production.
# GitHub OAuth app client id from GitHub Settings -> Developer settings -> OAuth Apps.
AUTH_GITHUB_ID=replace-with-github-oauth-app-client-id

# Required in production.
# GitHub OAuth app client secret from the same GitHub OAuth app.
AUTH_GITHUB_SECRET=replace-with-github-oauth-app-client-secret

# Local development only. Keep `false` in real deployments.
# Enables the built-in development credentials provider on `/sign-in`.
AUTH_ENABLE_DEV_CREDENTIALS=false

# Never enable in real production.
# Emergency override that allows dev credentials even when NODE_ENV=production.
AUTH_ALLOW_DEV_CREDENTIALS_IN_PRODUCTION=false

# Optional. Default role for development credentials and other non-bootstrap fallbacks.
# Valid values: member, admin, owner
AUTH_DEFAULT_WORKSPACE_ROLE=member

# Optional but recommended for the very first hosted sign-in.
# The first matching identity is allowed to seed the initial persisted owner membership.
AUTH_BOOTSTRAP_USER_EMAIL=owner@agentgit.example

# Optional alternative to AUTH_BOOTSTRAP_USER_EMAIL.
# Use the GitHub login of the first owner if email matching is not reliable.
AUTH_BOOTSTRAP_GITHUB_LOGIN=agentgit-owner

# Optional. Role granted during first-owner bootstrap.
# Valid values: member, admin, owner
AUTH_BOOTSTRAP_WORKSPACE_ROLE=owner

# Optional but recommended for first launch only.
# Initial workspace id that is written once if bootstrap ownership needs to seed persistence.
AUTH_WORKSPACE_ID=ws_acme_01

# Optional but recommended for first launch only.
# Display name of the bootstrap workspace shown in the cloud UI.
AUTH_WORKSPACE_NAME=Acme platform

# Optional but recommended for first launch only.
# URL-safe slug for the bootstrap workspace and enterprise SSO provider id.
AUTH_WORKSPACE_SLUG=acme-platform

# -----------------------------------------------------------------------------
# Durable cloud persistence
# -----------------------------------------------------------------------------

# Required in production.
# PostgreSQL connection string for cloud-owned persistence.
# Get this from Neon, Supabase, Railway Postgres, or another managed Postgres provider.
DATABASE_URL=postgres://user:password@host:5432/agentgit_cloud?sslmode=require

# -----------------------------------------------------------------------------
# Workspace runtime and local-first inspection
# -----------------------------------------------------------------------------

# Required in production.
# Absolute path to the workspace root AgentGit Cloud is allowed to inspect locally.
# In Docker, mount this path into the container and point the variable at the mounted location.
AGENTGIT_ROOT=/var/lib/agentgit/workspaces/primary

# Required when the cloud app needs to inspect more than one workspace root.
# Comma-separated absolute paths. Keep aligned with mounted container paths.
AGENTGIT_CLOUD_WORKSPACE_ROOTS=/var/lib/agentgit/workspaces/primary

# Recommended.
# Cloud app log verbosity. Safe values: error, warn, info, debug.
AGENTGIT_CLOUD_LOG_LEVEL=info

# Optional but recommended.
# GitHub token used for repository identity verification and drift checks.
# Use a fine-grained PAT with read access to the repos the control plane must verify.
AGENTGIT_GITHUB_TOKEN=replace-with-github-token-for-repository-verification

# Optional fallback for AGENTGIT_GITHUB_TOKEN if your host injects GITHUB_TOKEN already.
GITHUB_TOKEN=replace-with-github-token-for-repository-verification

# Optional.
# Explicit path to the authority daemon socket if it does not live under the default workspace path.
AGENTGIT_SOCKET_PATH=/var/lib/agentgit/workspaces/primary/.agentgit/authority/authority.sock

# Optional overrides for policy file discovery. Leave unset unless you run a custom layout.
AGENTGIT_POLICY_CONFIG_PATH=
AGENTGIT_POLICY_WORKSPACE_CONFIG_PATH=
AGENTGIT_POLICY_CALIBRATION_CONFIG_PATH=
AGENTGIT_POLICY_GLOBAL_CONFIG_PATH=

# -----------------------------------------------------------------------------
# Notifications and delivery integrations
# -----------------------------------------------------------------------------

# Optional but required if you enable email notifications in production.
# Resend API key from the Resend dashboard.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Optional fallback sender address for Resend delivery if AGENTGIT_EMAIL_FROM is unset.
# Must be a verified sender/domain in Resend.
RESEND_FROM_EMAIL="AgentGit <noreply@agentgit.example>"

# Optional but required if you enable email notifications in production.
# Preferred sender header for approval and run notifications.
AGENTGIT_EMAIL_FROM="AgentGit <noreply@agentgit.example>"

# Optional but required if you enable Slack notifications in production.
# Slack incoming webhook URL from the target workspace/app configuration.
AGENTGIT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/replace-me

# Optional fallback for AGENTGIT_SLACK_WEBHOOK_URL.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/replace-me

# Optional.
# IANA time zone used for notification windows and business-hours rules.
AGENTGIT_NOTIFICATION_TIME_ZONE=America/New_York

# -----------------------------------------------------------------------------
# Observability, monitoring, and release hygiene
# -----------------------------------------------------------------------------

# Required in production.
# Sentry DSN for server-side runtime errors.
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Required in production.
# Sentry DSN exposed to the browser for client-side error capture.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Required when uploading source maps during production builds.
# Get this from Sentry -> Settings -> Auth Tokens.
SENTRY_AUTH_TOKEN=replace-with-sentry-auth-token

# Required when uploading source maps.
SENTRY_ORG=your-sentry-org

# Required when uploading source maps.
SENTRY_PROJECT=agentgit-cloud

# Recommended.
# Server-side tracing sample rate as a decimal between 0 and 1.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Recommended.
# Browser tracing sample rate as a decimal between 0 and 1.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional.
# Browser replay capture rate for sessions that hit an error.
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# Optional.
# Baseline browser replay capture rate for all sessions.
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0

# Required in production readiness checks once your external monitor exists.
# Point this at the dashboard URL for the uptime monitor that probes GET /api/v1/healthz.
AGENTGIT_UPTIME_MONITOR_URL=https://betterstack.com/monitors/agentgit-cloud

# Required in production readiness checks.
# Supported values: vercel, datadog
AGENTGIT_REQUEST_METRICS_PROVIDER=datadog

# Required when AGENTGIT_REQUEST_METRICS_PROVIDER=datadog.
# Datadog ingestion API key from your Datadog org.
DD_API_KEY=replace-with-datadog-api-key

# Optional alias used by some hosts instead of DD_API_KEY.
DATADOG_API_KEY=replace-with-datadog-api-key

# Required in production readiness checks after you create real Sentry alert rules.
AGENTGIT_SENTRY_ALERTS_CONFIGURED=true

# -----------------------------------------------------------------------------
# Hosting and browser security
# -----------------------------------------------------------------------------

# Optional unless browsers outside the app origin must call the API.
# Comma-separated allowlist for cross-origin API requests.
# Same-origin traffic works without this. Never use `*` in production.
AGENTGIT_CLOUD_ALLOWED_ORIGINS=https://cloud.agentgit.example

# -----------------------------------------------------------------------------
# Platform-provided variables
# -----------------------------------------------------------------------------

# These are usually injected by the host and do not need to be set manually:
# NODE_ENV
# NEXT_PHASE
# NEXTAUTH_SECRET (alias for AUTH_SECRET)
# NEXT_PUBLIC_VERCEL_ENV
# VERCEL
# VERCEL_ENV
# XDG_CONFIG_HOME
