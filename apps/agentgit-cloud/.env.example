AUTH_SECRET=replace-with-a-long-random-secret
AUTH_GITHUB_ID=replace-with-github-oauth-app-id
AUTH_GITHUB_SECRET=replace-with-github-oauth-app-secret
# Local development only. Production ignores this flag and keeps dev credentials disabled.
AUTH_ENABLE_DEV_CREDENTIALS=true
AUTH_DEFAULT_WORKSPACE_ROLE=admin
AUTH_WORKSPACE_ID=ws_acme_01
AUTH_WORKSPACE_NAME=Acme platform
AUTH_WORKSPACE_SLUG=acme-platform
AGENTGIT_ROOT=/Users/geoffreyfernald/Documents/agentgit
# Optional: comma-separated roots if the cloud app should hello more than one workspace.
AGENTGIT_CLOUD_WORKSPACE_ROOTS=/Users/geoffreyfernald/Documents/agentgit
AGENTGIT_CLOUD_LOG_LEVEL=info
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=replace-with-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=agentgit-cloud
